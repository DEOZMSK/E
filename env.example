# Публичные переменные для Next.js (NEXT_PUBLIC_*)
# NEXT_PUBLIC_SITE_URL заполните после покупки домена
# или после получения постоянного Vercel URL.
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_TITLE=EFITNES — персональное фитнес-сопровождение для женщин
NEXT_PUBLIC_SITE_DESCRIPTION=EFITNES — платформа фитнес-диагностики и персонального сопровождения: тренировки, питание и восстановление.
NEXT_PUBLIC_HERO_TITLE=Фитнес-сопровождение, которое учитывает ваш ритм жизни
NEXT_PUBLIC_HERO_SUBTITLE=EFITNES помогает выстроить тренировки, питание и восстановление с персональной поддержкой Елены.
NEXT_PUBLIC_TELEGRAM_LINK=https://t.me/EFITNES
NEXT_PUBLIC_LEAD_WEBHOOK=https://your-deploy.vercel.app/api/lead
NEXT_PUBLIC_AUTHOR_NAME=Elena
NEXT_PUBLIC_AUTHOR_ALIAS=Создатель EFITNES
NEXT_PUBLIC_AUTHOR_BIO=Фитнес-наставник для женщин. Автор EFITNES — проекта про диагностику, планирование и устойчивый результат.
NEXT_PUBLIC_AUTHOR_PHOTO=https://example.com/photo.png
NEXT_PUBLIC_STATS_CLIENTS=1700
NEXT_PUBLIC_STATS_YEARS=10
NEXT_PUBLIC_CONTACT_EMAIL=care@efitnes.example

# Секреты для Google Sheets (не публикуем)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=
GOOGLE_CALENDAR_ID=
BOOKING_TZ=Europe/Moscow
